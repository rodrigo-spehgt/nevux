{
  "name": "nevux",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/index.ts",
    "build": "vite build --outDir dist && esbuild server/index.ts --platform=node --bundle --format=esm --outfile=dist/server.js --define:process.env.NODE_ENV=\\\"production\\\"",
    "start": "NODE_ENV=production node dist/server.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "dotenv": "^17.2.2"
  },
  "devDependencies": {
    "vite": "^7.1.7",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.1",
    "@types/express": "^4.17.21",
    "@types/node": "^24.7.0",
    "typescript": "^5.9.3"
  }
}
